# Copy this file to secrets.yaml and fill in your real values.
# secrets.yaml is git-ignored and must NOT be committed.
# This is the single source of truth for every site-specific value; the rest
# of the project references it (the firmware via ESPHome !secret).

# --- Wi-Fi + API ---
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"

# 32-byte base64 key for the native API encryption.
# Must match the key Home Assistant has for this device
# (HA stores it in /config/esphome/secrets.yaml).
api_encryption_key: "base64-encoded-32-byte-key=="

# --- Home Assistant entities controlled/shown by the panel ---
power_entity: sensor.your_power        # sensor shown on screen (reports kW)
garage_open_switch: switch.your_garage_open
garage_close_switch: switch.your_garage_close
doorlock_switch: switch.your_door_lock

# --- AI usage entities shown in the panel's AI row ---
# Reset cells are HA template sensors computing minutes-to-reset.
claude_5h_entity: sensor.your_claude_5h_usage
claude_reset_entity: sensor.your_claude_reset_minutes
zai_5h_entity: sensor.your_zai_5h_quota
zai_reset_entity: sensor.your_zai_reset_minutes

# --- Temperature entities (shown on page 2 / temp_page) ---
temp_outside_entity: sensor.your_outside_temperature
temp_inside_entity: sensor.your_inside_temperature

# --- Network reference (not used by the build; OTA target passed on CLI) ---
ha_ip: 192.168.x.x          # Home Assistant host
cyd_ip: 192.168.x.x         # this CYD device (OTA)
